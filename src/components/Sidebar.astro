---

<aside
  class="fixed left-0 top-16 h-[calc(100vh-64px)] hidden md:flex flex-col bg-neo-bg w-64 border-r-[4px] border-neo-surface z-40"
>
  <div class="p-6 border-b-[4px] border-neo-surface bg-neo-container-highest">
    <div class="flex items-center gap-3">
      <div
        class="w-10 h-10 border-[2px] border-neo-surface neo-shadow bg-white overflow-hidden"
      >
        <img
          alt="Avatar"
          class="w-full h-full object-cover grayscale"
          src="https://lh3.googleusercontent.com/aida-public/AB6AXuDMCDMXDheuzlFJuwuIXw1-EW57P7hRxXJkKp06QTtUU_zbaw57b2awgprBPknW7TGPztqwfh0kbn5uGCRlI-AWXDgdpfGWqlebt5K3w8Z46RxKmI8-naIP7Pg8rp-m8bA1WmKWG1q07BNzA9g-JajSEy6AXtKdB-0t5vZ3gKcM6-eppLsf7U5IwtV2C-w6M3I5FmMm1235jpTo7FndPO6vqNuF4DSx_AEJT7AUmAwZ4z_Ji2WUAL7AyL5TgtUSUxev4zQ9Y12OChE"
        />
      </div>
      <div>
        <p class="font-display font-black text-xs leading-none">ARCHIVE_V2.0</p>
        <p
          class="font-mono text-[10px] text-neo-primary mt-1 uppercase tracking-widest"
        >
          STATUS: OPERATIONAL
        </p>
      </div>
    </div>
  </div>

  <nav class="flex-1 overflow-y-auto">
    <div class="flex flex-col">
      <a
        class="flex items-center gap-3 px-6 py-4 text-neo-surface border-b-[2px] border-neo-surface hover:bg-neo-secondary hover:text-white transition-all duration-75 font-display text-sm font-bold tracking-tight"
        href="/"
      >
        <span class="material-symbols-outlined">settings_input_component</span>
        01_SYSTEM_CORE
      </a>
      <a
        class="flex items-center gap-3 px-6 py-4 bg-neo-primary text-white border-b-[2px] border-neo-surface font-display text-sm font-bold tracking-tight"
        href="#"
      >
        <span
          class="material-symbols-outlined"
          style="font-variation-settings: 'FILL' 1;">database</span
        >
        02_DATA_DUMP
      </a>
      <a
        class="flex items-center gap-3 px-6 py-4 text-neo-surface border-b-[2px] border-neo-surface hover:bg-neo-secondary hover:text-white transition-all duration-75 font-display text-sm font-bold tracking-tight"
        href="#"
      >
        <span class="material-symbols-outlined">folder_open</span>
        03_ASSET_LOG
      </a>
      <a
        class="flex items-center gap-3 px-6 py-4 text-neo-surface border-b-[2px] border-neo-surface hover:bg-neo-secondary hover:text-white transition-all duration-75 font-display text-sm font-bold tracking-tight"
        href="#"
      >
        <span class="material-symbols-outlined">memory</span>
        04_PROCESSES
      </a>
      <a
        class="flex items-center gap-3 px-6 py-4 text-neo-surface border-b-[2px] border-neo-surface hover:bg-neo-secondary hover:text-white transition-all duration-75 font-display text-sm font-bold tracking-tight"
        href="#"
      >
        <span class="material-symbols-outlined">terminal</span>
        05_IO_STATUS
      </a>
    </div>

    <!-- Categories Section inside Nav -->
    <div class="mt-4 pb-4">
      <h4
        class="text-[10px] font-black font-display uppercase tracking-[0.2em] text-neo-surface opacity-50 mb-4 px-6 mt-4"
      >
        CATEGORIES
      </h4>
      <div class="flex flex-col border-t-[2px] border-neo-surface">
        <a
          class="flex items-center gap-4 px-6 py-3 border-b-[2px] border-neo-surface hover:bg-neo-container-highest transition-all group"
          href="#"
        >
          <div
            class="w-10 h-10 border-[2px] border-neo-surface bg-[#ffb702] flex items-center justify-center shrink-0"
          >
            <span class="material-symbols-outlined text-lg text-neo-surface"
              >javascript</span
            >
          </div>
          <div>
            <p
              class="font-display text-[10px] font-black uppercase text-neo-surface opacity-60 leading-none mb-1"
            >
              [JS] SCRIPT_CORE
            </p>
            <p
              class="font-display text-xs font-bold uppercase text-neo-surface group-hover:text-neo-primary transition-colors"
            >
              JAVASCRIPT
            </p>
          </div>
        </a>
        <a
          class="flex items-center gap-4 px-6 py-3 border-b-[2px] border-neo-surface hover:bg-neo-container-highest transition-all group"
          href="#"
        >
          <div
            class="w-10 h-10 border-[2px] border-neo-surface bg-[#448064] flex items-center justify-center shrink-0"
          >
            <span class="material-symbols-outlined text-lg text-white">css</span
            >
          </div>
          <div>
            <p
              class="font-display text-[10px] font-black uppercase text-neo-surface opacity-60 leading-none mb-1"
            >
              [CSS] STYLE_SHEET
            </p>
            <p
              class="font-display text-xs font-bold uppercase text-neo-surface group-hover:text-neo-primary transition-colors"
            >
              STYLING
            </p>
          </div>
        </a>
        <a
          class="flex items-center gap-4 px-6 py-3 border-b-[2px] border-neo-surface hover:bg-neo-container-highest transition-all group"
          href="#"
        >
          <div
            class="w-10 h-10 border-[2px] border-neo-surface bg-neo-primary flex items-center justify-center shrink-0"
          >
            <span class="material-symbols-outlined text-lg text-white"
              >settings_input_component</span
            >
          </div>
          <div>
            <p
              class="font-display text-[10px] font-black uppercase text-neo-surface opacity-60 leading-none mb-1"
            >
              [SYS] KERNEL_ARCH
            </p>
            <p
              class="font-display text-xs font-bold uppercase text-neo-surface group-hover:text-neo-primary transition-colors"
            >
              ARCHITECTURE
            </p>
          </div>
        </a>
      </div>
    </div>
  </nav>

  <div class="p-4 border-t-[4px] border-neo-surface bg-[#efeee3]">
    <button
      class="w-full py-2 bg-neo-primary text-white border-[2px] border-neo-surface neo-shadow font-display font-bold text-xs uppercase tracking-widest active:translate-x-[2px] active:translate-y-[2px] active:shadow-none transition-all"
    >
      REFRESH_LOGS
    </button>
  </div>
  <div class="flex border-t-[2px] border-neo-surface">
    <button
      class="flex-1 py-3 flex justify-center items-center hover:bg-neo-secondary hover:text-white transition-colors border-r-[2px] border-neo-surface"
    >
      <span class="material-symbols-outlined">settings</span>
    </button>
    <button
      class="flex-1 py-3 flex justify-center items-center hover:bg-neo-primary hover:text-white transition-colors"
    >
      <span class="material-symbols-outlined">power_settings_new</span>
    </button>
  </div>
</aside>
