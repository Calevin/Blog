---
interface Props {
  date: Date;
  class?: string;
  style?: 'long' | 'short';
}

const { date, class: className, style = 'long' } = Astro.props;
---

<time datetime={date.toISOString()} class={className}>
  {
    date.toLocaleDateString('es-AR', {
      year: 'numeric',
      month: style === 'long' ? 'long' : '2-digit',
      day: '2-digit',
    })
  }
</time>
