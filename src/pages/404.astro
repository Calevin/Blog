---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404_NOT_FOUND">
    <div
        class="grow flex items-center justify-center p-6 md:p-12 relative overflow-hidden min-h-[70vh]"
    >
        <!-- Background Decorative Grid -->
        <div
            class="absolute inset-0 opacity-[0.03] pointer-events-none"
            style="background-image: radial-gradient(var(--color-neo-surface) 1px, transparent 0); background-size: 24px 24px;"
        >
        </div>

        <!-- 404 Error Module -->
        <div
            class="relative w-full max-w-4xl bg-neo-bg border-4 border-neo-surface neo-shadow-lg overflow-hidden"
        >
            <!-- Header Component: Warning Stripes -->
            <div class="h-8 warning-stripes border-b-4 border-neo-surface">
            </div>

            <div class="p-8 md:p-12 flex flex-col items-center text-center">
                <!-- Glitchy Error Header -->
                <div class="relative mb-6">
                    <span
                        class="material-symbols-outlined text-8xl md:text-9xl text-neo-primary font-bold"
                        style="font-variation-settings: 'FILL' 1;">warning</span
                    >
                    <div
                        class="absolute -top-4 -right-4 bg-neo-primary text-white font-mono px-2 py-1 text-sm border-2 border-neo-surface"
                    >
                        FATAL_EXC
                    </div>
                </div>

                <h1
                    class="font-display text-5xl md:text-7xl font-black text-neo-surface uppercase tracking-tighter mb-4 leading-none"
                >
                    SYSTEM_ERROR:<br />
                    <span class="text-neo-primary">404_NOT_FOUND</span>
                </h1>

                <p
                    class="font-mono text-sm md:text-base text-neo-surface/80 max-w-xl mb-10 leading-relaxed"
                >
                    THE REQUESTED MODULE OR PAGE RESOURCE AT THIS SPECIFIED
                    ADDRESS DOES NOT EXIST IN THE CORE REPOSITORY. THE SECTOR IS
                    VOID OR HAS BEEN RELOCATED DURING THE LAST RECONSTRUCTION
                    PHASE.
                </p>

                <!-- Technical Diagnostics Panel -->
                <div
                    class="w-full bg-neo-container-highest border-4 border-neo-surface p-6 mb-10 text-left font-mono relative"
                >
                    <div
                        class="flex justify-between border-b-2 border-neo-surface/20 pb-2 mb-4"
                    >
                        <span class="text-[10px] font-bold uppercase opacity-60"
                            >DIAGNOSTIC_LOG_OVAL</span
                        >
                        <span
                            class="text-[10px] font-bold text-neo-primary animate-pulse"
                            >● LIVE_MONITOR</span
                        >
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs">
                        <div class="space-y-1">
                            <div
                                class="flex justify-between border-b border-neo-surface/10"
                            >
                                <span class="opacity-60">ERROR_CODE:</span>
                                <span class="font-bold">0x000404</span>
                            </div>
                            <div
                                class="flex justify-between border-b border-neo-surface/10"
                            >
                                <span class="opacity-60">TIMESTAMP:</span>
                                <span class="font-bold uppercase"
                                    >{
                                        new Date()
                                            .toISOString()
                                            .replace("T", " ")
                                            .substring(0, 19)
                                    }</span
                                >
                            </div>
                            <div
                                class="flex justify-between border-b border-neo-surface/10"
                            >
                                <span class="opacity-60">REQUEST_ID:</span>
                                <span class="font-bold">USR-992-DELTA</span>
                            </div>
                        </div>
                        <div class="space-y-1">
                            <div
                                class="flex justify-between border-b border-neo-surface/10"
                            >
                                <span class="opacity-60">RECOVERY_PTR:</span>
                                <span class="font-bold text-neo-secondary"
                                    >AVAILABLE</span
                                >
                            </div>
                            <div
                                class="flex justify-between border-b border-neo-surface/10"
                            >
                                <span class="opacity-60">STACK_TRACE:</span>
                                <span class="font-bold">NULL_REFERENCE</span>
                            </div>
                            <div
                                class="flex justify-between border-b border-neo-surface/10"
                            >
                                <span class="opacity-60">KERNEL_STATE:</span>
                                <span class="font-bold">STABLE_WAIT</span>
                            </div>
                        </div>
                    </div>

                    <!-- Mini Schematic Decoration -->
                    <div
                        class="mt-6 border-t-2 border-dashed border-neo-surface/30 pt-4 flex gap-2"
                    >
                        <div class="h-2 w-1/4 bg-neo-primary"></div>
                        <div class="h-2 w-2/4 bg-neo-tertiary"></div>
                        <div class="h-2 w-1/4 bg-neo-surface"></div>
                    </div>
                </div>

                <!-- Action Button -->
                <a class="group relative inline-block" href="/">
                    <div
                        class="absolute inset-0 bg-neo-surface translate-x-1.5 translate-y-1.5 transition-transform group-hover:translate-x-0 group-hover:translate-y-0"
                    >
                    </div>
                    <button
                        class="relative bg-neo-primary text-white border-4 border-neo-surface px-10 py-4 font-display font-black text-xl uppercase tracking-tighter flex items-center gap-3 active:translate-x-0.5 active:translate-y-0.5"
                    >
                        <span class="material-symbols-outlined">refresh</span>
                        REBOOT_TO_HOME
                    </button>
                </a>
            </div>

            <!-- Footer Component: Warning Stripes -->
            <div class="h-4 warning-stripes border-t-4 border-neo-surface">
            </div>
        </div>

        <!-- Asymmetric Floating Background Elements -->
        <div
            class="absolute top-20 right-20 w-32 h-32 border-4 border-neo-surface bg-neo-secondary/10 rotate-12 -z-10 hidden lg:block"
        >
        </div>
        <div
            class="absolute bottom-20 left-20 w-48 h-12 border-4 border-neo-surface bg-neo-secondary/10 -rotate-3 -z-10 hidden lg:block"
        >
        </div>
    </div>
</Layout>

<style>
    .warning-stripes {
        background: repeating-linear-gradient(
            45deg,
            var(--color-neo-tertiary),
            var(--color-neo-tertiary) 10px,
            var(--color-neo-surface) 10px,
            var(--color-neo-surface) 20px
        );
    }
</style>
